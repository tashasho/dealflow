# === Core Required ===
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Any OpenRouter model slug. See https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini

# === Slack delivery (pick ONE path) ===
# Path A — bot token + channel ID (preferred for routing to a specific channel)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=C0B3HUF3LRJ
# Path B — incoming webhook (channel is fixed at webhook creation time)
SLACK_WEBHOOK_URL=

# === Slack interactive triage server (optional) ===
SLACK_SIGNING_SECRET=your-signing-secret

# === Sourcing APIs (Required for full pipeline) ===
GITHUB_TOKEN=ghp_your_github_token
APIFY_TOKEN=your-apify-token
PHANTOMBUSTER_API_KEY=your-phantombuster-key
PHANTOMBUSTER_AGENT_ID=your-agent-id

# === Enrichment APIs ===
CRUNCHBASE_API_KEY=your-crunchbase-key
APOLLO_API_KEY=your-apollo-key
CLAY_API_KEY=your-clay-key

# === Configuration ===
SCORE_THRESHOLD=75
